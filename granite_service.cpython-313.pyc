"""
SkillBridge AI — IBM watsonx.ai Granite Service
Handles all AI interactions via IBM watsonx.ai
"""

import os
import json
import logging
import re
from ibm_watsonx_ai import Credentials
from ibm_watsonx_ai.foundation_models import ModelInference
from ibm_watsonx_ai.metanames import GenTextParamsMetaNames as GenParams

logger = logging.getLogger(__name__)


# ─────────────────────────────────────────────
# SYSTEM PROMPT
# ─────────────────────────────────────────────
SKILLBRIDGE_SYSTEM_PROMPT = """You are SkillBridge AI, an award-winning AI Job Mentor built using IBM Granite on IBM Cloud.

MISSION: Empower informal workers — daily wage laborers, artisans, gig workers, street vendors, domestic workers, delivery partners, drivers, farmers, construction workers, self-employed individuals, and unemployed youth — to improve careers, increase income, develop skills, discover employment, and understand government support programs.

PERSONALITY: Friendly, professional, encouraging, respectful, patient, motivational, and easy to understand.

LANGUAGE RULE: Always reply in the same language used by the user. Support English, Hindi, Hinglish.

CORE RULES:
- Read the user's question carefully and answer ONLY what they asked.
- Never give a generic career guidance response when the user asked something specific.
- Never fabricate jobs, salaries, government benefits, or eligibility criteria.
- Never ask for information the user has already provided.
- Always personalize responses using available user information.
- Provide practical, actionable advice.
- Keep responses concise, organized with bullet points, headings, and emojis.
- End every response with 3-4 follow-up suggestions relevant to what the user asked.
- Warn against scams, fake recruiters, and paid job offers where relevant.
- For government schemes, always remind users to verify through official portals.

RESPONSE FORMAT:
- Use emojis for section headers.
- Use bullet points and short paragraphs.
- Keep language simple and accessible.
- Be encouraging and build confidence.
- ALWAYS directly answer the user's question first before adding any extra information.
"""


class GraniteService:
    """Wrapper around IBM watsonx.ai Granite for SkillBridge AI"""

    def __init__(self):
        self.api_key   = os.getenv("IBM_CLOUD_API_KEY", "")
        self.project_id = os.getenv("PROJECT_ID", "")
        self.model_id  = os.getenv("MODEL_ID", "ibm/granite-13b-instruct-v2")
        self.url       = os.getenv("IBM_WATSONX_URL", "https://us-south.ml.cloud.ibm.com")
        self._model    = None
        self._init_model()

    def _init_model(self):
        try:
            if not self.api_key or not self.project_id:
                logger.warning("IBM watsonx.ai credentials not configured. Using fallback mode.")
                return

            credentials = Credentials(url=self.url, api_key=self.api_key)

            params = {
                GenParams.MAX_NEW_TOKENS:      1024,
                GenParams.MIN_NEW_TOKENS:      10,
                GenParams.TEMPERATURE:         0.7,
                GenParams.TOP_P:               0.9,
                GenParams.TOP_K:               50,
                GenParams.REPETITION_PENALTY:  1.1,
                GenParams.STOP_SEQUENCES:      ["Human:", "User:"],
            }

            self._model = ModelInference(
                model_id=self.model_id,
                credentials=credentials,
                project_id=self.project_id,
                params=params,
            )
            logger.info(f"Granite model initialized: {self.model_id}")

        except Exception as e:
            logger.error(f"Failed to initialize Granite model: {e}")
            self._model = None

    def _build_prompt(self, system: str, user_message: str, history: list = None) -> str:
        """Build a formatted prompt for Granite."""
        prompt = f"{system}\n\n"
        if history:
            for msg in history[-6:]:
                role    = msg.get("role", "user")
                content = msg.get("content", "")
                if role == "user":
                    prompt += f"Human: {content}\n"
                else:
                    prompt += f"Assistant: {content}\n"
        prompt += f"Human: {user_message}\nAssistant:"
        return prompt

    def _call_granite(self, prompt: str, max_tokens: int = 1024) -> str:
        """Call the Granite model and return text response."""
        if not self._model:
            # Pass only the raw user message to fallback, NOT the full prompt
            return None   # signal to caller to use targeted fallback
        try:
            response = self._model.generate_text(prompt=prompt)
            text = (response or "").strip()
            return text if text else None
        except Exception as e:
            logger.error(f"Granite API error: {e}")
            return None

    # ─────────────────────────────────────────────
    # TARGETED FALLBACK — answers the ACTUAL question
    # ─────────────────────────────────────────────
    def _fallback_for_message(self, user_message: str, user_profile: dict = None) -> str:
        """
        Generate a response that directly answers the user's actual question.
        Keyword matching is done ONLY against the user's message, never the system prompt.
        """
        msg = user_message.lower().strip()
        profile = user_profile or {}

        # ── Greeting ──────────────────────────────────────────────────────────
        greet_words = ["hello", "hi", "hey", "namaste", "namaskar", "halo",
                       "good morning", "good afternoon", "good evening",
                       "हेलो", "नमस्ते", "हाय"]
        if any(w in msg for w in greet_words) and len(msg.split()) <= 5:
            name = profile.get("name", "")
            greeting = f"Hello {name}! 👋" if name else "Hello! 👋"
            return (
                f"{greeting} I'm **SkillBridge AI** — your personal Career Mentor powered by IBM Granite.\n\n"
                "I can help you with:\n\n"
                "💼 **Finding jobs** that match your skills\n"
                "🏛 **Government schemes** for free training and support\n"
                "📚 **Skill development** — free courses and certifications\n"
                "📝 **Resume building** — ATS-friendly tips\n"
                "🎤 **Interview preparation** — practice Q&A\n"
                "💰 **Financial guidance** — savings, banking, insurance\n\n"
                "What would you like help with today? 😊\n\n"
                "➡ **Quick start:** Tell me your current job, location, and career goal."
            )

        # ── Scam alert (check BEFORE job — "fake job scam" must not hit job block) ──
        scam_words = ["scam", "fraud", "fake", "cheat", "payment for job",
                      "pay for job", "job fee", "ठगी", "धोखा", "फर्जी"]
        if any(w in msg for w in scam_words):
            return (
                "⚠️ **Job Scam Alert — Protect Yourself!**\n\n"
                "**Signs of a fake job offer:**\n"
                "• They ask you to **pay money** for registration, training, or ID card\n"
                "• Job offer arrives without any interview\n"
                "• Salary promised is unrealistically high (e.g., ₹50,000/day for simple work)\n"
                "• They ask for your **Aadhaar, bank details, or OTP**\n"
                "• Contact only via WhatsApp or unknown numbers — no office address\n\n"
                "**How to stay safe:**\n"
                "• **Never pay money for a job.** Real employers NEVER charge fees.\n"
                "• Verify companies on Google before applying\n"
                "• Use only trusted portals: Apna, WorkIndia, NCS Portal, Naukri\n"
                "• If someone asks for OTP — hang up immediately\n"
                "• Report scams to cybercrime.gov.in or call 1930\n\n"
                "SkillBridge AI is 100% free. We will never ask for payment."
            )

        # ── Gig / freelance (check BEFORE job — "freelance work" must not hit job block) ──
        gig_words = ["gig", "freelance", "part time", "part-time", "side job",
                     "extra income", "work from home", "online work", "ghar se kaam",
                     "घर से काम"]
        if any(w in msg for w in gig_words):
            return (
                "🤝 **Gig Work & Freelance Opportunities**\n\n"
                "**Popular gig platforms in India:**\n\n"
                "• **Delivery** — Swiggy, Zomato, Dunzo, Porter, Blinkit\n"
                "• **Rides** — Ola, Uber, Rapido (bike taxi)\n"
                "• **Home services** — Urban Company (electrician, plumber, cleaner)\n"
                "• **Freelance tasks** — Fiverr, Upwork, Truelancer (design, writing, data entry)\n"
