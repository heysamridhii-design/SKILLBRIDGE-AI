    # ─────────────────────────────────────────────
    # CORE CHAT
    # ─────────────────────────────────────────────
    def chat(self, user_message: str, user_profile: dict, chat_history: list,
             language: str, agent_instructions: dict) -> dict:
        """Main chat handler — sends user message to Granite, falls back to targeted response."""

        # Build profile context string
        profile_context = ""
        if user_profile:
            parts = []
            if user_profile.get("name"):       parts.append(f"Name: {user_profile['name']}")
            if user_profile.get("occupation"): parts.append(f"Occupation: {user_profile['occupation']}")
            if user_profile.get("location"):   parts.append(f"Location: {user_profile['location']}")
            if user_profile.get("skills"):     parts.append(f"Skills: {user_profile['skills']}")
            if user_profile.get("career_goal"):parts.append(f"Career Goal: {user_profile['career_goal']}")
            if user_profile.get("education"):  parts.append(f"Education: {user_profile['education']}")
            profile_context = " | ".join(parts)

        lang_instruction = ""
        if language == "hi":
            lang_instruction = "IMPORTANT: Respond entirely in Hindi language.\n"
        elif language == "hinglish":
            lang_instruction = "IMPORTANT: Respond in Hinglish (natural mix of Hindi and English).\n"

        # Assemble system section
        system = SKILLBRIDGE_SYSTEM_PROMPT
        if profile_context:
            system += f"\nUSER PROFILE: {profile_context}\n"
        if lang_instruction:
            system += f"\n{lang_instruction}"
        system += f"\nPersonality: {agent_instructions.get('personality', '')}"
        system += f"\nSafety rules: {agent_instructions.get('safety_rules', '')}"

        # Detect intents from user message only
        intents = self._detect_intents(user_message)

        # Build and call Granite
        prompt = self._build_prompt(system, user_message, chat_history)
        reply  = self._call_granite(prompt, max_tokens=1024)

        # If Granite unavailable or returned empty — use targeted fallback
        if not reply:
            reply = self._fallback_for_message(user_message, user_profile)

        suggestions = self._generate_suggestions(intents)

        return {
            "reply":       reply,
            "intents":     intents,
            "suggestions": suggestions,
        }

    def _detect_intents(self, message: str) -> list:
        """Detect intents from user message ONLY."""
        msg = message.lower()
        intents = []
        intent_map = {
            "job":       ["job", "naukri", "work", "employment", "vacancy", "hiring",
                          "jobs in", "job near", "नौकरी", "काम", "रोजगार"],
            "skill":     ["skill", "learn", "course", "training", "sikhna", "seekhna",
                          "certificate", "कौशल", "सीखना"],
            "scheme":    ["scheme", "yojana", "government", "sarkar", "benefit",
                          "subsidy", "sarkari", "सरकारी", "योजना"],
            "resume":    ["resume", "cv", "biodata", "रिज्यूमे", "बायोडाटा"],
            "interview": ["interview", "prepare", "preparation", "इंटरव्यू"],
            "finance":   ["money", "savings", "bank", "loan", "insurance",
                          "paisa", "upi", "पैसा", "बचत", "financial"],
            "scam":      ["scam", "fraud", "fake", "cheat", "ठगी", "धोखा"],
            "career":    ["career", "roadmap", "career plan", "career goal",
                          "career advice", "guidance"],
            "gig":       ["freelance", "gig", "part-time", "part time",
                          "side job", "extra income"],
            "salary":    ["salary", "pay", "income", "wage", "kitna milega",
                          "वेतन", "तनख्वाह"],
        }
        for intent, keywords in intent_map.items():
            if any(kw in msg for kw in keywords):
                intents.append(intent)
        if not intents:
            intents = ["general"]
        return intents

    def _generate_suggestions(self, intents: list) -> list:
        """Generate follow-up suggestion chips based on detected intents."""
        suggestion_map = {
            "job":       "💼 Find Nearby Jobs",
            "skill":     "📚 Learn New Skills",
            "scheme":    "🏛 Explore Government Support",
            "resume":    "📝 Build My Resume",
            "interview": "🎤 Prepare for Interview",
            "finance":   "💰 Financial Guidance",
            "career":    "🎯 View Career Roadmap",
            "gig":       "🤝 Explore Gig Work",
            "salary":    "💵 Check Salary Guide",
            "scam":      "⚠️ Scam Safety Tips",
            "general":   "👤 Complete My Profile",
        }
        result = []
        for intent in intents[:2]:
            chip = suggestion_map.get(intent)
            if chip:
                result.append(chip)
        defaults = ["💼 Find Nearby Jobs", "📚 Learn New Skills",
                    "🏛 Government Schemes", "📝 Build My Resume"]
        for d in defaults:
            if d not in result and len(result) < 4:
                result.append(d)
        return result[:4]

    # ─────────────────────────────────────────────
    # JOB RECOMMENDATIONS (Jobs page)
    # ─────────────────────────────────────────────
    def recommend_jobs(self, profile: dict, agent_instructions: dict) -> dict:
        occupation = profile.get("occupation", "general worker")
        skills     = profile.get("skills", "basic skills")
        location   = profile.get("location", "India")
        education  = profile.get("education", "10th pass")
        goal       = profile.get("career_goal", "better job")

        prompt = self._build_prompt(
            SKILLBRIDGE_SYSTEM_PROMPT,
            f"""Recommend 4 suitable jobs for:
Occupation: {occupation} | Skills: {skills} | Location: {location}
Education: {education} | Goal: {goal}

Return a JSON array. Each item: title, industry, match_score, salary_range, required_skills (array), why_match, next_step.
Respond with ONLY the JSON array, no extra text."""
        )

        raw = self._call_granite(prompt, max_tokens=1200)
        if raw:
            try:
                m = re.search(r'\[.*\]', raw, re.DOTALL)
                if m:
                    return {"jobs": json.loads(m.group())}
            except Exception:
                pass

        return {"jobs": [
            {"title": "Delivery Partner", "industry": "Logistics & E-Commerce",
             "match_score": 88, "salary_range": "₹15,000–₹25,000/month",
             "required_skills": ["Two-wheeler riding", "Smartphone", "Navigation"],
             "why_match": "High demand, flexible hours, no fixed education requirement.",
             "next_step": "Register on Swiggy, Zomato, or Amazon Flex app."},
            {"title": "Retail Sales Associate", "industry": "Retail",
             "match_score": 82, "salary_range": "₹12,000–₹18,000/month",
             "required_skills": ["Communication", "Basic math", "Customer service"],
             "why_match": "Steady income, growth to supervisor roles.",
             "next_step": "Apply on WorkIndia or visit local malls."},
            {"title": "Security Guard", "industry": "Security Services",
             "match_score": 78, "salary_range": "₹13,000–₹20,000/month",
             "required_skills": ["Physical fitness", "Alertness", "Communication"],
             "why_match": "Stable employment with ESI + PF benefits.",
             "next_step": "Contact G4S, Securitas, or local security agencies."},
            {"title": "Data Entry Operator", "industry": "IT / BPO",
             "match_score": 72, "salary_range": "₹10,000–₹18,000/month",
             "required_skills": ["Basic computer", "Typing", "Accuracy"],
             "why_match": "Work from home options available, growing demand.",
             "next_step": "Apply on Naukri.com or Indeed India."},
        ]}

    # ─────────────────────────────────────────────
    # GOVERNMENT SCHEMES (Schemes page)
    # ─────────────────────────────────────────────
    def recommend_schemes(self, profile: dict, agent_instructions: dict) -> dict:
        occupation = profile.get("occupation", "informal worker")
        age        = profile.get("age", "adult")
        gender     = profile.get("gender", "")
        location   = profile.get("location", "India")

        prompt = self._build_prompt(
            SKILLBRIDGE_SYSTEM_PROMPT,
            f"""Recommend 4 relevant Indian government schemes for:
Occupation: {occupation} | Age: {age} | Gender: {gender} | Location: {location}

Return a JSON array. Each item: name, purpose, beneficiaries, benefits, documents, how_to_apply, portal.
Respond with ONLY the JSON array."""
        )

        raw = self._call_granite(prompt, max_tokens=1200)
        if raw:
            try:
                m = re.search(r'\[.*\]', raw, re.DOTALL)
                if m:
                    return {"schemes": json.loads(m.group())}
            except Exception:
                pass

        return {"schemes": [
            {"name": "PM Kaushal Vikas Yojana (PMKVY)",
             "purpose": "Free skill training and certification",
             "beneficiaries": "Youth 15–45, informal workers",
             "benefits": "Free training, certificate, ₹8,000 reward",
             "documents": "Aadhaar Card, Bank Account, Photo",
             "how_to_apply": "Visit nearest PMKVY center or skillindiadigital.gov.in",
             "portal": "skillindiadigital.gov.in"},
            {"name": "e-Shram Portal",
             "purpose": "Social security for unorganized workers",
             "beneficiaries": "All informal workers aged 16–59",
             "benefits": "₹2 lakh accident insurance",
             "documents": "Aadhaar Card, Aadhaar-linked mobile",
             "how_to_apply": "Register at eshram.gov.in or CSC center",
             "portal": "eshram.gov.in"},
            {"name": "PM Mudra Yojana",
             "purpose": "Business loans for micro-enterprises",
             "beneficiaries": "Small business owners, self-employed",
             "benefits": "Loans up to ₹10 lakh, no collateral",
             "documents": "ID proof, address proof, business plan",
             "how_to_apply": "Apply at any bank or mudra.org.in",
             "portal": "mudra.org.in"},
            {"name": "PM Jan Dhan Yojana",
             "purpose": "Zero-balance bank account",
             "beneficiaries": "All Indian citizens",
             "benefits": "Free account, RuPay card, ₹1L accident insurance",
             "documents": "Aadhaar or government ID",
             "how_to_apply": "Visit nearest bank branch",
             "portal": "pmjdy.gov.in"},
        ]}

    # ─────────────────────────────────────────────
    # SKILL GAP ANALYSIS
    # ─────────────────────────────────────────────
    def analyze_skill_gap(self, profile: dict, goal: str, agent_instructions: dict) -> dict:
        skills     = profile.get("skills", "")
        occupation = profile.get("occupation", "")

        prompt = self._build_prompt(
            SKILLBRIDGE_SYSTEM_PROMPT,
            f"""Analyze skill gap:
Current Skills: {skills} | Current Job: {occupation} | Career Goal: {goal}

Return JSON with keys: existing_skills (array), missing_skills (array), priority_skills (array),
learning_time (string), certifications (array), tips (array).
Respond with ONLY the JSON object."""
        )

        raw = self._call_granite(prompt, max_tokens=1000)
        if raw:
            try:
                m = re.search(r'\{.*\}', raw, re.DOTALL)
                if m:
                    return {"analysis": json.loads(m.group())}
            except Exception:
                pass

        return {"analysis": {
            "existing_skills":  ["Basic communication", "Physical endurance", "Local area knowledge"],
            "missing_skills":   ["Digital literacy", "English communication", "Computer basics"],
            "priority_skills":  ["Smartphone & app usage", "Basic English", "UPI payments"],
            "learning_time":    "4–8 weeks with 1 hour daily practice",
            "certifications":   ["Google Digital Unlocked (free)", "PMKVY (free)"],
            "tips": ["Start with free YouTube tutorials in Hindi",
                     "Practice digital payments using PhonePe or GPay",
                     "Join a local PMKVY training center for hands-on learning"],
        }}

    # ─────────────────────────────────────────────
    # RESUME ANALYZER
    # ─────────────────────────────────────────────
    def analyze_resume(self, resume_text: str, profile: dict, agent_instructions: dict) -> dict:
        if not resume_text:
            return {
                "score": 30, "strengths": [],
                "improvements": ["Add a professional summary", "List your key skills",
                                 "Include work experience with dates", "Add contact information"],
                "ats_keywords": [], "suggested_summary": "",
            }

        prompt = self._build_prompt(
            SKILLBRIDGE_SYSTEM_PROMPT,
            f"""Analyze this resume and provide ATS feedback:

RESUME:
{resume_text[:2000]}

Return JSON: score (0-100), strengths (array), improvements (array), ats_keywords (array), suggested_summary (string).
Respond with ONLY the JSON object."""
        )

        raw = self._call_granite(prompt, max_tokens=900)
        if raw:
            try:
                m = re.search(r'\{.*\}', raw, re.DOTALL)
                if m:
                    return json.loads(m.group())
            except Exception:
                pass

        return {
            "score": 55,
            "strengths": ["Has work experience listed", "Contact information present"],
            "improvements": [
                "Add a professional summary at the top",
                "Quantify achievements (e.g., served 50+ customers daily)",
                "Use action verbs: managed, coordinated, achieved",
                "Include relevant certifications",
                "Keep to 1 page for entry-level",
            ],
            "ats_keywords": ["customer service", "teamwork", "reliability", "time management"],
            "suggested_summary": "Dedicated worker with hands-on experience seeking stable employment.",
        }

    # ─────────────────────────────────────────────
    # INTERVIEW PREP
    # ─────────────────────────────────────────────
    def interview_prep(self, job_role: str, profile: dict, agent_instructions: dict) -> dict:
        prompt = self._build_prompt(
            SKILLBRIDGE_SYSTEM_PROMPT,
            f"""Generate interview preparation for the role: {job_role}
User background: {profile.get('occupation', 'informal worker')}

Return JSON: questions (array of {{question, answer}}), tips (array), dress_code (string), salary_tip (string).
Respond with ONLY the JSON object."""
        )

        raw = self._call_granite(prompt, max_tokens=1100)
        if raw:
            try:
                m = re.search(r'\{.*\}', raw, re.DOTALL)
                if m:
                    return json.loads(m.group())
            except Exception:
                pass

        return {
            "questions": [
                {"question": "Tell me about yourself.",
                 "answer": "Keep it under 2 minutes. Name → experience → skills → goal."},
                {"question": "Why do you want this job?",
                 "answer": "Show genuine interest. Mention how your skills match their needs."},
                {"question": "What are your strengths?",
                 "answer": "Reliability, hard work, quick learner — pick 2–3 relevant ones."},
                {"question": "Where do you see yourself in 5 years?",
                 "answer": "Show ambition: growing within this company, taking on responsibility."},
                {"question": "What is your salary expectation?",
                 "answer": "Give a range based on market research: 'I expect ₹X–₹Y for this role.'"},
            ],
            "tips": [
                "Practice answers out loud the night before.",
                "Arrive 10 minutes early with extra resume copies.",
                "Make eye contact and speak slowly and clearly.",
                "It's okay to pause and think before answering.",
                "Follow up with a thank-you message after the interview.",
            ],
            "dress_code": "Wear clean, pressed formal or semi-formal clothes. Keep hair neat.",
            "salary_tip": "Research market rate on Naukri or Glassdoor before negotiating.",
        }

    # ─────────────────────────────────────────────
    # CAREER ROADMAP
    # ─────────────────────────────────────────────
    def generate_roadmap(self, profile: dict, agent_instructions: dict) -> dict:
        goal       = profile.get("career_goal", "better employment")
        occupation = profile.get("occupation", "informal worker")
        skills     = profile.get("skills", "")

        prompt = self._build_prompt(
            SKILLBRIDGE_SYSTEM_PROMPT,
            f"""Create a 6-step career roadmap for:
Current: {occupation} | Goal: {goal} | Skills: {skills}

Return JSON: {{roadmap: [{{step_number, title, description, duration, action_items}}]}}.
Respond with ONLY the JSON object."""
        )

        raw = self._call_granite(prompt, max_tokens=1000)
        if raw:
            try:
                m = re.search(r'\{.*\}', raw, re.DOTALL)
                if m:
                    return json.loads(m.group())
            except Exception:
                pass

        return {"roadmap": [
            {"step_number": 1, "title": "Complete Your Profile",
             "description": "Fill in skills, location, and career goal.",
             "duration": "Today", "action_items": ["Add skills", "Set career goal"]},
            {"step_number": 2, "title": "Build Your Resume",
             "description": "Create an ATS-friendly resume.",
             "duration": "1–2 days", "action_items": ["Use Canva or Naukri Builder"]},
            {"step_number": 3, "title": "Learn New Skills",
             "description": "Take free courses to close skill gaps.",
             "duration": "4–8 weeks", "action_items": ["Enroll in PMKVY", "SWAYAM courses"]},
            {"step_number": 4, "title": "Apply for Jobs",
             "description": "Apply on verified portals every day.",
             "duration": "Ongoing", "action_items": ["Apna App", "WorkIndia", "NCS Portal"]},
            {"step_number": 5, "title": "Ace the Interview",
             "description": "Practice with AI Interview Coach.",
             "duration": "Before interview", "action_items": ["Mock practice", "Prepare documents"]},
            {"step_number": 6, "title": "Get Hired & Grow",
             "description": "Start your new role and keep upskilling.",
             "duration": "Ongoing", "action_items": ["Ask for feedback", "Set next goal"]},
        ]}

    # ─────────────────────────────────────────────
    # DAILY CAREER TIP
    # ─────────────────────────────────────────────
    def get_daily_career_tip(self, language: str = "en") -> str:
        import random
        tips_en = [
            "💡 Every skill you learn today is an investment in tomorrow's income.",
            "💡 Register on e-Shram Portal — free ₹2 lakh accident insurance in 5 minutes!",
            "💡 A clean, honest resume gets more interviews than an exaggerated one.",
            "💡 Practice speaking English for 10 minutes daily — it opens many doors.",
            "💡 Never pay money for a job offer. Genuine employers never charge fees.",
            "💡 Save at least 10% of every income you earn, no matter how small.",
            "💡 PMKVY offers free certified skill training near you — enroll today.",
            "💡 Your network is your net worth — build good relationships at every job.",
        ]
        tips_hi = [
            "💡 आज सीखा हर कौशल कल की आमदनी में निवेश है।",
            "💡 ई-श्रम पोर्टल पर पंजीकरण करें — मुफ्त दुर्घटना बीमा पाएं।",
            "💡 कभी भी नौकरी के लिए पैसे न दें। असली नियोक्ता कभी फीस नहीं मांगते।",
            "💡 हर आमदनी का कम से कम 10% बचाएं।",
        ]
        if language == "hi":
            return random.choice(tips_hi)
        return random.choice(tips_en)
