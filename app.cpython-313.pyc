/**
 * SkillBridge AI — Frontend JavaScript
 * Handles chat, voice, dark mode, language, and UI interactions
 */

'use strict';

// ─────────────────────────────────────────────
// GLOBALS
// ─────────────────────────────────────────────
let currentLanguage = localStorage.getItem('sb_language') || 'en';
let isRecording     = false;
let recognition     = null;
let synth           = window.speechSynthesis;

// ─────────────────────────────────────────────
// DARK MODE
// ─────────────────────────────────────────────
function toggleDarkMode() {
  fetch('/api/toggle-dark-mode', { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      document.body.classList.toggle('dark-mode', data.dark_mode);
      updateDarkIcon(data.dark_mode);
    })
    .catch(() => {
      document.body.classList.toggle('dark-mode');
      updateDarkIcon(document.body.classList.contains('dark-mode'));
    });
}

function updateDarkIcon(isDark) {
  const icon = document.getElementById('darkIcon');
  if (!icon) return;
  icon.className = isDark ? 'bi bi-sun-fill' : 'bi bi-moon-stars';
}

// ─────────────────────────────────────────────
// LANGUAGE
// ─────────────────────────────────────────────
function setLanguage(lang) {
  currentLanguage = lang;
  localStorage.setItem('sb_language', lang);
  fetch('/api/set-language', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ language: lang }),
  });
}

// ─────────────────────────────────────────────
// CHAT — SEND MESSAGE
// ─────────────────────────────────────────────
async function sendMessage() {
  const input   = document.getElementById('userInput');
  const sendBtn = document.getElementById('sendBtn');
  if (!input) return;

  const message = input.value.trim();
  if (!message) return;

  // Clear input
  input.value  = '';
  input.style.height = 'auto';

  // Disable send button
  if (sendBtn) sendBtn.disabled = true;

  // Render user message
  appendUserMessage(message);
  scrollToBottom();

  // Show typing
  showTyping();

  try {
    const response = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message, language: currentLanguage }),
    });

    const data = await response.json();
    hideTyping();

    const reply = data.reply || 'I encountered an issue. Please try again.';
    appendAIMessage(reply, data.timestamp, data.suggestions || []);
    scrollToBottom();

    // Render suggestion chips
    renderInputChips(data.suggestions || []);

    // TTS if enabled
    if (localStorage.getItem('sb_tts') === 'true') {
      speak(reply.replace(/[*#_~`]/g, '').substring(0, 300));
    }
  } catch (err) {
    hideTyping();
    appendAIMessage(
      '⚠️ I am having trouble connecting right now. Please check your internet and try again.',
      new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      []
    );
    scrollToBottom();
  } finally {
    if (sendBtn) sendBtn.disabled = false;
  }
}

// ─────────────────────────────────────────────
// QUICK SEND (Sidebar Topics / Hero Chips)
// ─────────────────────────────────────────────
function sendQuick(text) {
  const input = document.getElementById('userInput');
  if (input) {
    input.value = text;
    sendMessage();
  } else {
    // Redirect to chat page with pre-filled query
    window.location.href = `/chat?q=${encodeURIComponent(text)}`;
  }
}

// ─────────────────────────────────────────────
// MESSAGE RENDERING
// ─────────────────────────────────────────────
function appendUserMessage(text) {
  const container = document.getElementById('chatMessages');
  if (!container) return;

  const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  const div  = document.createElement('div');
  div.className = 'chat-msg user-msg-wrap';
  div.innerHTML = `
    <div class="user-bubble">
      <div class="bubble-text">${escapeHtml(text)}</div>
      <div class="bubble-time">${time}</div>
    </div>
  `;
  container.appendChild(div);
  div.querySelector('.user-bubble').classList.add('animate-fade-up');
}

function appendAIMessage(text, timestamp, suggestions) {
  const container = document.getElementById('chatMessages');
  if (!container) return;

  const time = timestamp || new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

  // Format markdown-like text
  const formatted = formatAIText(text);

  const chipsHtml = suggestions && suggestions.length
    ? `<div class="suggestion-chips">${
        suggestions.map(s => `<button class="chip" onclick="sendQuick('${escapeAttr(s)}')">${escapeHtml(s)}</button>`).join('')
      }</div>`
    : '';

  const div = document.createElement('div');
  div.className = 'chat-msg ai-msg-wrap';
  div.innerHTML = `
    <div class="ai-avatar">🤖</div>
    <div class="ai-bubble glass-card animate-fade-up">
      <div class="ai-bubble-header">
        <span class="fw-semibold">SkillBridge AI</span>
        <span class="msg-time">${time}</span>
      </div>
      <div class="ai-bubble-body">${formatted}</div>
      ${chipsHtml}
    </div>
  `;
  container.appendChild(div);
}

function formatAIText(text) {
  if (!text) return '';

  let html = text
    // Bold: **text**
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    // Italic: *text*
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    // Markdown table rows: | col | col | → keep as-is for now, handled below
    // Numbered headings like **1. Title** already handled by bold above
    // Arrow lines: → text
    .replace(/^→ (.+)$/gm, '<span class="ai-arrow">→ $1</span>')
    // Bullet: • item or - item at line start
    .replace(/^[•\-] (.+)$/gm, '<li>$1</li>')
    // Numbered list: 1. or 1️⃣
    .replace(/^\d+[.️⃣]\s*(.+)$/gm, '<li>$1</li>');

  // Wrap consecutive <li> blocks in <ul>
  html = html.replace(/(<li>[\s\S]*?<\/li>)(\s*<li>[\s\S]*?<\/li>)*/g, match => `<ul>${match}</ul>`);

  // Convert remaining newlines to paragraphs
  const lines = html.split('\n');
  const parts = [];
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    // Already wrapped HTML tags — don't double-wrap
    if (trimmed.startsWith('<ul>') || trimmed.startsWith('<li>') ||
        trimmed.startsWith('<strong>') || trimmed.startsWith('<span')) {
      parts.push(trimmed);
    } else {
      parts.push(`<p>${trimmed}</p>`);
    }
  }
  return parts.join('');
}

// ─────────────────────────────────────────────
// TYPING INDICATOR
// ─────────────────────────────────────────────
function showTyping() {
  const el = document.getElementById('typingIndicator');
  if (el) el.classList.remove('d-none');
}

function hideTyping() {
  const el = document.getElementById('typingIndicator');
  if (el) el.classList.add('d-none');
}

// ─────────────────────────────────────────────
// SCROLL TO BOTTOM
// ─────────────────────────────────────────────
function scrollToBottom() {
  const container = document.getElementById('chatMessages');
  if (container) {
    setTimeout(() => {
      container.scrollTo({ top: container.scrollHeight, behavior: 'smooth' });
    }, 100);
  }
}

// ─────────────────────────────────────────────
// SUGGESTION CHIPS IN INPUT AREA
// ─────────────────────────────────────────────
function renderInputChips(suggestions) {
  const toolbar = document.getElementById('suggestionChips');
  if (!toolbar || !suggestions.length) return;
  toolbar.innerHTML = suggestions
    .map(s => `<button class="chip" onclick="sendQuick('${escapeAttr(s)}')">${escapeHtml(s)}</button>`)
    .join('');
}

// ─────────────────────────────────────────────
// KEYBOARD HANDLING
// ─────────────────────────────────────────────
function handleEnter(event) {
  if (event.key === 'Enter' && !event.shiftKey) {
    event.preventDefault();
    sendMessage();
  }
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

// ─────────────────────────────────────────────
// VOICE INPUT (Web Speech API)
// ─────────────────────────────────────────────
function startVoice() {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
    alert('Voice input is not supported in your browser. Please use Chrome or Edge.');
    return;
  }

  if (isRecording) {
    stopVoice();
    return;
  }

  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SpeechRecognition();

  const langMap = { en: 'en-IN', hi: 'hi-IN', hinglish: 'hi-IN' };
  recognition.lang = langMap[currentLanguage] || 'en-IN';
  recognition.continuous = false;
  recognition.interimResults = false;
  recognition.maxAlternatives = 1;

  recognition.onstart = () => {
    isRecording = true;
    const btn = document.getElementById('voiceBtn');
    if (btn) {
      btn.classList.add('recording');
      btn.innerHTML = '<i class="bi bi-mic-mute-fill"></i>';
    }

    // Show voice modal
    const modal = document.getElementById('voiceModal');
    if (modal) {
      const bsModal = new bootstrap.Modal(modal);
      bsModal.show();
    }
  };

  recognition.onresult = (event) => {
    const transcript = event.results[0][0].transcript;
    const input = document.getElementById('userInput');
    if (input) {
      input.value = transcript;
      autoResize(input);
    }
    stopVoice();
  };

  recognition.onerror = (event) => {
    console.error('Speech recognition error:', event.error);
    stopVoice();
  };

  recognition.onend = () => {
    stopVoice();
    const input = document.getElementById('userInput');
    if (input && input.value.trim()) {
      setTimeout(sendMessage, 300);
    }
  };

  recognition.start();
}

function stopVoice() {
  isRecording = false;
  if (recognition) {
    recognition.stop();
    recognition = null;
  }
  const btn = document.getElementById('voiceBtn');
  if (btn) {
    btn.classList.remove('recording');
    btn.innerHTML = '<i class="bi bi-mic-fill"></i>';
  }
  // Hide voice modal
  const modal = document.getElementById('voiceModal');
  if (modal) {
    const bsModal = bootstrap.Modal.getInstance(modal);
    if (bsModal) bsModal.hide();
  }
}

// ─────────────────────────────────────────────
// TEXT-TO-SPEECH
// ─────────────────────────────────────────────
function speak(text) {
  if (!synth || !text) return;
  synth.cancel();
  const utter = new SpeechSynthesisUtterance(text);
  const langMap = { en: 'en-IN', hi: 'hi-IN', hinglish: 'hi-IN' };
  utter.lang = langMap[currentLanguage] || 'en-IN';
  utter.rate = 0.95;
  utter.pitch = 1;
  synth.speak(utter);
}

function toggleTTS() {
  const current = localStorage.getItem('sb_tts') === 'true';
  localStorage.setItem('sb_tts', (!current).toString());
  return !current;
}

// ─────────────────────────────────────────────
// CLEAR CHAT HISTORY
// ─────────────────────────────────────────────
function clearHistory() {
  if (!confirm('Clear all chat history? This cannot be undone.')) return;
  fetch('/api/clear-history', { method: 'POST' })
    .then(() => {
      const container = document.getElementById('chatMessages');
      if (container) {
        container.innerHTML = `
          <div class="chat-msg ai-msg-wrap">
            <div class="ai-avatar">🤖</div>
            <div class="ai-bubble glass-card">
              <div class="ai-bubble-header">
                <span class="fw-semibold">SkillBridge AI</span>
                <span class="msg-time">Now</span>
              </div>
              <div class="ai-bubble-body">Chat history cleared. How can I help you today? 😊</div>
            </div>
          </div>
        `;
      }
    });
}

// ─────────────────────────────────────────────
// UTILITY HELPERS
// ─────────────────────────────────────────────
function escapeHtml(str) {
  const div = document.createElement('div');
  div.appendChild(document.createTextNode(str || ''));
  return div.innerHTML;
}

function escapeAttr(str) {
  return (str || '').replace(/'/g, '&#39;').replace(/"/g, '&quot;');
}

function showError(containerId, message) {
  const el = document.getElementById(containerId);
  if (el) {
    el.innerHTML = `<div class="alert alert-danger">${escapeHtml(message)}</div>`;
  }
}

// ─────────────────────────────────────────────
// SCROLL ANIMATIONS (Intersection Observer)
// ─────────────────────────────────────────────
function initScrollAnimations() {
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity   = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.feature-card, .step-card, .scheme-card, .job-card, .worker-chip').forEach(el => {
    el.style.opacity   = '0';
    el.style.transform = 'translateY(20px)';
    el.style.transition = 'opacity .5s ease, transform .5s ease';
    observer.observe(el);
  });
}

// ─────────────────────────────────────────────
// SMOOTH SCROLL
// ─────────────────────────────────────────────
function initSmoothScroll() {
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      const target = document.querySelector(anchor.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
}

// ─────────────────────────────────────────────
// PROFILE QUICK UPDATE VIA API
// ─────────────────────────────────────────────
async function updateProfileField(field, value) {
  if (!value) return;
  try {
    const res = await fetch('/api/profile/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ [field]: value }),
    });
    return await res.json();
  } catch (err) {
    console.error('Profile update error:', err);
  }
}

// ─────────────────────────────────────────────
// SHARE / COPY
// ─────────────────────────────────────────────
async function copyToClipboard(text) {
  try {
    await navigator.clipboard.writeText(text);
    showToast('Copied to clipboard!');
  } catch {
    const ta = document.createElement('textarea');
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('Copied!');
  }
}

// ─────────────────────────────────────────────
// TOAST NOTIFICATION
// ─────────────────────────────────────────────
function showToast(message, type = 'success') {
  // Remove existing toasts
  document.querySelectorAll('.sb-toast').forEach(t => t.remove());

  const colors = {
    success: '#10B981',
    error:   '#ef4444',
    info:    '#2563EB',
    warning: '#F59E0B',
  };

  const toast = document.createElement('div');
  toast.className = 'sb-toast';
  toast.style.cssText = `
    position: fixed;
    bottom: 80px;
    right: 20px;
    background: ${colors[type] || colors.info};
    color: white;
    padding: .65rem 1.2rem;
    border-radius: 10px;
    font-size: .85rem;
    font-weight: 600;
    z-index: 9999;
    box-shadow: 0 4px 20px rgba(0,0,0,.2);
    animation: fadeInUp .3s ease;
    max-width: 280px;
  `;
  toast.textContent = message;
  document.body.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}

// ─────────────────────────────────────────────
// STATS COUNTER ANIMATION
// ─────────────────────────────────────────────
function animateCounters(selector = '.widget-num') {
  document.querySelectorAll(selector).forEach(el => {
    const target = parseInt(el.dataset.target) || 0;
    if (target === 0) { el.textContent = '0'; return; }

    let count  = 0;
    const step = Math.max(1, Math.ceil(target / 50));
    const timer = setInterval(() => {
      count = Math.min(count + step, target);
      el.textContent = count;
      if (count >= target) clearInterval(timer);
    }, 35);
  });
}

// ─────────────────────────────────────────────
// INIT ON DOM READY
// ─────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  // Sync dark mode icon
  const isDark = document.body.classList.contains('dark-mode');
  updateDarkIcon(isDark);

  // Language from storage
  const storedLang = localStorage.getItem('sb_language');
  if (storedLang) currentLanguage = storedLang;

  // Init scroll animations
  if (typeof IntersectionObserver !== 'undefined') {
    initScrollAnimations();
  }

  // Smooth scroll
  initSmoothScroll();

  // Animate widget counters if present
  if (document.querySelector('.widget-num')) {
    animateCounters('.widget-num');
  }

  // Auto-focus chat input
  const chatInput = document.getElementById('userInput');
  if (chatInput) {
    chatInput.focus();
  }

  // Scroll chat to bottom on page load
  scrollToBottom();

  // Navbar scroll effect
  window.addEventListener('scroll', () => {
    const navbar = document.querySelector('.sb-navbar');
    if (navbar) {
      navbar.style.boxShadow = window.scrollY > 10
        ? '0 2px 20px rgba(0,0,0,.08)'
        : 'none';
    }
  });
});
